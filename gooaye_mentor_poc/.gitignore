# Raw RSS snapshots and generated manifests
data/rss/*.xml
data/manifests/*.jsonl
data/manifests/*.csv

# Downloaded and generated audio
data/audio/
data/benchmarks/**/*.mp3
data/review_clips/
*.mp3
*.wav
*.m4a
*.flac
*.aac

# Generated transcripts
data/transcripts/
